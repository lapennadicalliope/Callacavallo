<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Call a cavallo! — La Penna di Calliope</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --color-primary: #c25613;
            --color-white: #ffffff;
            --color-black: #0a0a0a;
            --color-cream: #faf8f5;
            --color-warm: #f5f0ea;
            --color-muted: #8a7e74;
            --nav-height: 80px;
        }
        html { scroll-behavior: smooth; font-size: 16px; -webkit-text-size-adjust: 100%; }
        body {
            font-family: 'Source Sans 3', sans-serif;
            background-color: var(--color-cream);
            color: var(--color-black);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            line-height: 1.6;
        }
        .preloader {
            position: fixed; inset: 0; z-index: 99999; background: var(--color-white);
            display: flex; align-items: center; justify-content: center; flex-direction: column;
            gap: 1.5rem; transition: opacity 0.8s ease, visibility 0.8s ease;
        }
        .preloader.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
        .preloader-logo { width: 80px; height: 80px; animation: fadeUp 0.8s ease 0.3s forwards; opacity: 0; }
        .preloader-logo img { width: 100%; height: 100%; object-fit: contain; }
        .preloader-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(0.9rem, 2vw, 1.2rem);
            color: var(--color-primary);
            letter-spacing: 0.4em; text-transform: uppercase; opacity: 0;
            animation: fadeUp 0.8s ease 0.5s forwards, preloaderPulse 1.5s ease-in-out 1.3s infinite;
        }
        @keyframes preloaderPulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
        
        /* Cursor removed as requested to simplify */
        
        .particles { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
        .particle {
            position: absolute; width: 2px; height: 2px; background: var(--color-primary);
            border-radius: 50%; opacity: 0; animation: particleFloat linear infinite;
        }
        @keyframes particleFloat {
            0% { opacity: 0; transform: translateY(100vh) scale(0); }
            10% { opacity: 0.6; } 90% { opacity: 0.6; }
            100% { opacity: 0; transform: translateY(-10vh) scale(1); }
        }
        .nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            padding: 1.5rem clamp(1.5rem, 4vw, 4rem);
            display: flex; justify-content: space-between; align-items: center;
            transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            height: var(--nav-height);
        }
        .nav.scrolled {
            background: rgba(255,255,255,0.97); backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px); padding: 0.8rem clamp(1.5rem, 4vw, 4rem);
            box-shadow: 0 1px 30px rgba(0,0,0,0.06);
        }
        .nav.hero-nav { background: transparent; }
        .nav.hero-nav .nav-logo-text { color: var(--color-black); }
        .nav.hero-nav .nav-link-plain { color: var(--color-muted); }
        .nav.hero-nav .nav-link-plain:hover { color: var(--color-black); }
        .nav.hero-nav .nav-cta { color: var(--color-primary); border-color: var(--color-primary); }
        .nav.hero-nav .nav-cta:hover { background: var(--color-primary); color: var(--color-white) !important; }
        .nav.hero-nav .hamburger span { background: var(--color-black); }
        .nav.scrolled .nav-logo-icon { width: 28px; height: 28px; }
        .nav-logo-link { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
        .nav-logo-icon { width: 32px; height: 32px; transition: all 0.4s ease; }
        .nav-logo-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(0.85rem, 1.5vw, 1.1rem); font-weight: 600;
            color: var(--color-white); letter-spacing: 0.15em; text-transform: uppercase;
            transition: color 0.4s ease;
        }
        .nav.scrolled .nav-logo-text { color: var(--color-black); }
        .nav-links { display: flex; align-items: center; gap: 2rem; }
        .nav-link-plain {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(0.75rem, 1.2vw, 0.9rem); font-weight: 600;
            letter-spacing: 0.15em; text-transform: uppercase;
            color: rgba(255,255,255,0.7); text-decoration: none;
            transition: color 0.3s ease; white-space: nowrap;
        }
        .nav.scrolled .nav-link-plain { color: var(--color-muted); }
        .nav-link-plain:hover { color: var(--color-white); }
        .nav.scrolled .nav-link-plain:hover { color: var(--color-primary); }
        .nav-cta {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(0.75rem, 1.2vw, 0.9rem); font-weight: 600;
            letter-spacing: 0.2em; text-transform: uppercase;
            color: var(--color-white); text-decoration: none;
            padding: 0.6rem 1.5rem; border: 1px solid rgba(255,255,255,0.3);
            transition: all 0.4s ease; white-space: nowrap;
        }
        .nav.scrolled .nav-cta { color: var(--color-primary); border-color: var(--color-primary); }
        .nav-cta:hover { background: var(--color-primary); color: var(--color-white) !important; border-color: var(--color-primary); }
        .hamburger {
            display: none; flex-direction: column; gap: 5px; cursor: pointer;
            padding: 8px; z-index: 1001; background: none; border: none;
        }
        .hamburger span { display: block; width: 24px; height: 1.5px; background: var(--color-white); transition: all 0.3s ease; transform-origin: center; }
        .nav.scrolled .hamburger span { background: var(--color-black); }
        .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(4px, 5px); }
        .hamburger.active span:nth-child(2) { opacity: 0; }
        .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(4px, -5px); }
        .mobile-menu {
            display: none; position: fixed; inset: 0;
            background: rgba(255,255,255,0.98); backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px); z-index: 999;
            flex-direction: column; align-items: center; justify-content: center;
            gap: 2rem; opacity: 0; visibility: hidden; transition: all 0.5s ease;
        }
        .mobile-menu.active { opacity: 1; visibility: visible; }
        .mobile-menu a {
            font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 400;
            color: var(--color-black); text-decoration: none; letter-spacing: 0.1em;
            opacity: 0; transform: translateY(20px); transition: all 0.4s ease;
        }
        .mobile-menu.active a { opacity: 1; transform: translateY(0); }
        .mobile-menu.active a:nth-child(1) { transition-delay: 0.1s; }
        .mobile-menu.active a:nth-child(2) { transition-delay: 0.2s; }
        .mobile-menu.active a:nth-child(3) { transition-delay: 0.3s; }
        .mobile-menu.active a:nth-child(4) { transition-delay: 0.4s; }
        .mobile-menu.active a:nth-child(5) { transition-delay: 0.5s; }
        .mobile-menu a:hover { color: var(--color-primary); }
        .hero {
            position: relative; min-height: 100vh; min-height: 100dvh;
            display: flex; align-items: center; justify-content: center;
            background: var(--color-white); overflow: hidden;
        }
        .hero-bg-pattern {
            position: absolute; inset: 0; opacity: 0.04;
            background-image:
                radial-gradient(circle at 20% 50%, var(--color-primary) 1px, transparent 1px),
                radial-gradient(circle at 80% 20%, var(--color-primary) 1px, transparent 1px),
                radial-gradient(circle at 60% 80%, var(--color-primary) 1px, transparent 1px);
            background-size: 60px 60px, 80px 80px, 70px 70px;
            animation: patternDrift 30s linear infinite;
        }
        @keyframes patternDrift { 0% { transform: translate(0,0); } 100% { transform: translate(60px,60px); } }
        .hero-gradient {
            position: absolute; inset: 0;
            background:
                radial-gradient(ellipse at 30% 50%, rgba(194,86,19,0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 30%, rgba(194,86,19,0.04) 0%, transparent 50%);
        }
        .hero-content {
            position: relative; z-index: 2; text-align: center;
            max-width: 900px; padding: 2rem; width: 100%;
        }
        .hero-logo {
            width: clamp(120px, 20vw, 180px); height: clamp(120px, 20vw, 180px);
            margin: 0 auto 2.5rem; opacity: 0; animation: fadeUp 1s ease 0.5s forwards;
        }
        .hero-logo img { width: 100%; height: 100%; object-fit: contain; }
        .hero-eyebrow {
            font-family: 'Source Sans 3', sans-serif;
            font-size: clamp(0.65rem, 1.2vw, 0.8rem); font-weight: 400;
            letter-spacing: clamp(0.3em, 0.8vw, 0.5em); text-transform: uppercase;
            color: var(--color-primary); margin-bottom: 1.5rem;
            opacity: 0; animation: fadeUp 1s ease 0.7s forwards;
        }
        .hero-title {
            font-family: 'Playfair Display', serif; font-size: clamp(2rem, 5vw, 5rem);
            font-weight: 400; line-height: 1.15; color: var(--color-black);
            margin-bottom: 1rem; opacity: 0; animation: fadeUp 1s ease 0.9s forwards;
        }
        .hero-title em { font-style: italic; color: var(--color-primary); }
        .hero-subtitle {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 2vw, 1.6rem);
            font-weight: 300; font-style: italic; color: var(--color-muted);
            margin-bottom: 2.5rem; opacity: 0; animation: fadeUp 1s ease 1.1s forwards; line-height: 1.5;
        }
        .hero-cta-group {
            display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap;
            opacity: 0; animation: fadeUp 1s ease 1.3s forwards;
        }
        .btn-primary {
            display: inline-flex; align-items: center; gap: 0.6rem;
            font-family: 'Cormorant Garamond', serif; font-size: clamp(0.85rem, 1.2vw, 1rem);
            font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;
            color: var(--color-white); background: var(--color-primary);
            padding: clamp(0.8rem, 1.5vw, 1.1rem) clamp(1.5rem, 3vw, 2.5rem);
            text-decoration: none; border: none; cursor: pointer;
            transition: all 0.4s ease; position: relative; overflow: hidden; white-space: nowrap;
        }
        .btn-primary::before {
            content: ''; position: absolute; inset: 0; background: var(--color-black);
            transform: translateX(-100%); transition: transform 0.4s ease;
        }
        .btn-primary:hover::before { transform: translateX(0); }
        .btn-primary:hover { color: var(--color-white); }
        .btn-primary span, .btn-primary svg { position: relative; z-index: 1; }
        .btn-secondary {
            display: inline-flex; align-items: center; gap: 0.6rem;
            font-family: 'Cormorant Garamond', serif; font-size: clamp(0.85rem, 1.2vw, 1rem);
            font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;
            color: var(--color-black); padding: clamp(0.8rem, 1.5vw, 1.1rem) clamp(1.5rem, 3vw, 2.5rem);
            text-decoration: none; border: 1px solid rgba(10,10,10,0.2); transition: all 0.4s ease; white-space: nowrap;
        }
        .btn-secondary:hover { color: var(--color-primary); border-color: var(--color-primary); }
        .scroll-indicator {
            position: absolute; bottom: clamp(2rem, 4vh, 3rem); left: 50%;
            transform: translateX(-50%); display: flex; flex-direction: column;
            align-items: center; gap: 0.5rem; opacity: 0; animation: fadeUp 1s ease 1.8s forwards;
        }
        .scroll-indicator span {
            font-family: 'Source Sans 3', sans-serif; font-size: 0.6rem;
            letter-spacing: 0.3em; text-transform: uppercase; color: rgba(10,10,10,0.3);
        }
        .scroll-line {
            width: 1px; height: 35px;
            background: linear-gradient(to bottom, var(--color-primary), transparent);
            animation: scrollPulse 2s ease-in-out infinite;
        }
        @keyframes scrollPulse { 0%, 100% { transform: scaleY(1); opacity: 1; } 50% { transform: scaleY(0.5); opacity: 0.3; } }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        .section-divider { display: flex; align-items: center; justify-content: center; padding: 0; }
        .section-divider .line { flex: 1; max-width: 200px; height: 1px; background: var(--color-primary); opacity: 0.3; }
        .section-divider .diamond { width: 8px; height: 8px; background: var(--color-primary); transform: rotate(45deg); margin: 0 1.5rem; flex-shrink: 0; }
        .manifesto {
            padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 4vw, 3rem);
            max-width: 800px; margin: 0 auto; background: var(--color-cream);
        }
        .manifesto-label {
            font-family: 'Source Sans 3', sans-serif; font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.5em; text-transform: uppercase; color: var(--color-primary);
            margin-bottom: 2.5rem; text-align: center;
        }
        .manifesto-text {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1.1rem, 1.8vw, 1.5rem);
            font-weight: 300; line-height: 1.8; color: var(--color-black);
        }
        .manifesto-text p { margin-bottom: 1.5rem; }
        .manifesto-text p:last-child { margin-bottom: 0; }
        .manifesto-text strong { font-weight: 600; color: var(--color-primary); }
        .manifesto-text em { font-style: italic; }
        .chi-siamo-section {
            padding: clamp(5rem, 10vw, 9rem) clamp(1.5rem, 4vw, 3rem);
            text-align: center; background: var(--color-warm); position: relative;
        }
        .chi-siamo-inner { max-width: 750px; margin: 0 auto; }
        .chi-siamo-label {
            font-family: 'Source Sans 3', sans-serif; font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.5em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 2.5rem;
        }
        .chi-siamo-title {
            font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.5rem);
            font-weight: 400; margin-bottom: 2rem; color: var(--color-black);
        }
        .chi-siamo-title em { color: var(--color-primary); font-style: italic; }
        .chi-siamo-content {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 1.5vw, 1.2rem);
            line-height: 1.75; color: var(--color-muted);
        }
        .chi-siamo-content p { margin-bottom: 1.2rem; }
        .chi-siamo-content p:last-child { margin-bottom: 0; }
        .chi-siamo-content strong { font-weight: 600; color: var(--color-black); }
        .chi-siamo-content em { font-style: italic; color: var(--color-primary); }
        .timeline-section {
            padding: clamp(5rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3rem);
            background: var(--color-black); color: var(--color-white);
        }
        .timeline-inner { max-width: 800px; margin: 0 auto; }
        .timeline-header { text-align: center; margin-bottom: clamp(2.5rem, 5vw, 4rem); }
        .timeline-header h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.5rem); font-weight: 400; }
        .timeline-header h2 em { color: var(--color-primary); }
        .timeline { position: relative; padding-left: clamp(2rem, 4vw, 3rem); }
        .timeline::before {
            content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 1px;
            background: linear-gradient(to bottom, var(--color-primary), rgba(194,86,19,0.1));
        }
        .timeline-item {
            position: relative; padding-bottom: clamp(2rem, 4vw, 3rem);
            opacity: 0; transform: translateX(-20px); transition: all 0.6s ease;
        }
        .timeline-item.visible { opacity: 1; transform: translateX(0); }
        .timeline-item::before {
            content: ''; position: absolute; left: clamp(-2rem, -4vw, -3rem); top: 0.4rem;
            width: 9px; height: 9px; background: var(--color-primary);
            border-radius: 50%; transform: translateX(-4px);
        }
        .timeline-date {
            font-family: 'Source Sans 3', sans-serif; font-size: clamp(0.65rem, 1vw, 0.75rem);
            font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase;
            color: var(--color-primary); margin-bottom: 0.4rem;
        }
        .timeline-title {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1.1rem, 1.5vw, 1.3rem);
            font-weight: 600; margin-bottom: 0.4rem; color: var(--color-white);
        }
        .timeline-desc {
            font-family: 'Source Sans 3', sans-serif; font-size: clamp(0.85rem, 1vw, 0.95rem);
            color: rgba(255,255,255,0.65); line-height: 1.6; font-weight: 300;
        }
        .bando-section {
            padding: clamp(6rem, 10vw, 9rem) clamp(1.5rem, 4vw, 3rem);
            text-align: center; background: var(--color-cream); position: relative;
        }
        .bando-section::before {
            content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
            width: 1px; height: 60px; background: linear-gradient(to bottom, transparent, var(--color-primary));
        }
        .bando-inner { max-width: 700px; margin: 0 auto; }
        .bando-label {
            font-family: 'Source Sans 3', sans-serif; font-size: 0.7rem; font-weight: 600;
            letter-spacing: 0.5em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 2rem;
        }
        .bando-title {
            font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3.5vw, 3.2rem);
            font-weight: 400; margin-bottom: 1.5rem; color: var(--color-black);
        }
        .bando-title em { color: var(--color-primary); font-style: italic; }
        .bando-description {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 1.5vw, 1.2rem);
            line-height: 1.7; color: var(--color-muted); margin-bottom: 2.5rem;
        }
        .bando-download {
            display: inline-flex; align-items: center; gap: 0.8rem;
            padding: clamp(1rem, 2vw, 1.5rem) clamp(2rem, 4vw, 3rem);
            background: var(--color-primary); color: var(--color-white); text-decoration: none;
            font-family: 'Cormorant Garamond', serif; font-size: clamp(0.9rem, 1.2vw, 1.1rem);
            font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;
            transition: all 0.4s ease; position: relative; overflow: hidden; border: none; cursor: pointer;
        }
        .bando-download::before {
            content: ''; position: absolute; inset: 0; background: var(--color-black);
            transform: translateY(100%); transition: transform 0.4s ease;
        }
        .bando-download:hover::before { transform: translateY(0); }
        .bando-download:hover { color: var(--color-white); }
        .bando-download svg, .bando-download span { position: relative; z-index: 1; }
        .bando-note {
            margin-top: 1.2rem; font-family: 'Source Sans 3', sans-serif;
            font-size: clamp(0.7rem, 1vw, 0.8rem); color: var(--color-muted); font-style: italic;
        }
        .contact-section {
            padding: clamp(5rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3rem);
            text-align: center; background: var(--color-warm);
        }
        .contact-inner { max-width: 600px; margin: 0 auto; }
        .contact-section h2 {
            font-family: 'Playfair Display', serif; font-size: clamp(1.6rem, 3vw, 2.5rem);
            font-weight: 400; margin-bottom: 1.5rem;
        }
        .contact-section h2 em { color: var(--color-primary); }
        .contact-section p {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 1.5vw, 1.15rem);
            color: var(--color-muted); line-height: 1.7; margin-bottom: 2.5rem;
        }
        .contact-links { display: flex; flex-direction: column; align-items: center; gap: 1.2rem; }
        .contact-link-item {
            display: inline-flex; align-items: center; gap: 0.7rem;
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 1.5vw, 1.15rem);
            font-weight: 600; color: var(--color-primary); text-decoration: none;
            letter-spacing: 0.08em; transition: all 0.3s ease;
            padding-bottom: 3px; border-bottom: 1px solid transparent;
        }
        .contact-link-item:hover { border-bottom-color: var(--color-primary); }
        .contact-link-item svg { width: 20px; height: 20px; flex-shrink: 0; }
        .footer {
            padding: clamp(2.5rem, 4vw, 3.5rem) clamp(1.5rem, 4vw, 3rem);
            background: var(--color-black); text-align: center;
        }
        .footer-logo {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(1rem, 1.5vw, 1.2rem);
            font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase;
            color: var(--color-white); margin-bottom: 0.8rem;
        }
        .footer-text {
            font-family: 'Source Sans 3', sans-serif; font-size: clamp(0.65rem, 1vw, 0.75rem);
            color: rgba(255,255,255,0.35); letter-spacing: 0.15em;
        }
        .footer-tagline {
            font-family: 'Cormorant Garamond', serif; font-size: clamp(0.8rem, 1vw, 0.9rem);
            font-style: italic; color: rgba(255,255,255,0.2); margin-top: 1.2rem;
        }
        .footer-social { margin-top: 1.2rem; display: flex; justify-content: center; gap: 1.2rem; }
        .footer-social a {
            display: flex; align-items: center; justify-content: center;
            width: 36px; height: 36px; border-radius: 50%;
            border: 1px solid rgba(255,255,255,0.15); transition: all 0.3s ease; color: rgba(255,255,255,0.4);
        }
        .footer-social a:hover { border-color: var(--color-primary); color: var(--color-primary); background: rgba(194,86,19,0.1); }
        .footer-social a svg { width: 16px; height: 16px; }
        
        .reveal { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
        .reveal.visible { opacity: 1; transform: translateY(0); }
        .reveal-delay-1 { transition-delay: 0.1s; }
        .reveal-delay-2 { transition-delay: 0.2s; }
        .reveal-delay-3 { transition-delay: 0.3s; }
        @media (max-width: 768px) {
            :root { --nav-height: 64px; }
            .nav-links { display: none; }
            .hamburger { display: flex; }
            .mobile-menu { display: flex; }
            .hero-content { padding: 1.5rem; }
            .hero-cta-group { flex-direction: column; align-items: center; gap: 1rem; }
            .btn-primary, .btn-secondary { width: 100%; max-width: 300px; justify-content: center; }
        }
        @media (max-width: 480px) {
            .hero-logo { margin-bottom: 2rem; }
            .hero-eyebrow { letter-spacing: 0.2em; font-size: 0.6rem; }
            .section-divider .diamond { margin: 0 1rem; width: 6px; height: 6px; }
        }
        @supports (padding-top: env(safe-area-inset-top)) {
            .nav { padding-top: calc(1.5rem + env(safe-area-inset-top)); }
            .hero { padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom); }
        }
    </style>
</head>
<body>

<div class="preloader" id="preloader">
    <div class="preloader-logo">
        <!-- Placeholder for logo.png in preloader -->
        <img src="logo.png" alt="Logo Preloader" onerror="this.style.display='none'">
    </div>
    <span class="preloader-text">Calliope</span>
</div>

<div class="particles" id="particles"></div>

<nav class="nav hero-nav" id="nav">
    <a href="#" class="nav-logo-link">
        <!-- Placeholder for logo.png in nav -->
        <img class="nav-logo-icon" src="logo.png" alt="Logo" onerror="this.style.display='none'">
        <span class="nav-logo-text">La Penna di Calliope</span>
    </a>
    <div class="nav-links">
        <a href="#scopri" class="nav-link-plain">Chi Siamo</a>
        <a href="#chi-siamo" class="nav-link-plain">Il Bando</a>
        <a href="#bando" class="nav-cta">Scarica il Bando</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
    <a href="#hero" class="mobile-menu-link">Home</a>
    <a href="#scopri" class="mobile-menu-link">Chi Siamo</a>
    <a href="#chi-siamo" class="mobile-menu-link">Il Bando</a>
    <a href="#percorso" class="mobile-menu-link">Percorso</a>
    <a href="#bando" class="mobile-menu-link">Scarica il Bando</a>
</div>

<section class="hero" id="hero">
    <div class="hero-bg-pattern"></div>
    <div class="hero-gradient"></div>
    <div class="hero-content">
        <div class="hero-logo" id="heroLogo">
            <!-- Placeholder for logo.png in hero -->
            <img src="logo.png" alt="La Penna di Calliope Logo" onerror="this.style.display='none'">
        </div>
        <div class="hero-eyebrow">Antologia poetica · Napoli 2026</div>
        <h1 class="hero-title" id="heroTitle">
            La Penna di Calliope<br><em>vuole pubblicare con te</em>
        </h1>
        <p class="hero-subtitle" id="heroSubtitle">
            Call a cavallo! — Il bando di poesia per voci che sanno<br>
            trasformare Napoli in versi
        </p>
        <div class="hero-cta-group">
            <a href="bando.pdf" download class="btn-primary">
                <span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Scarica il Bando
                </span>
            </a>
            <a href="#scopri" class="btn-secondary">
                Scopri di più
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>
    </div>
    <div class="scroll-indicator">
        <span>Scorri</span>
        <div class="scroll-line"></div>
    </div>
</section>

<!-- Chi Siamo / Manifesto -->
<section class="manifesto" id="scopri">
    <div class="manifesto-label reveal">Chi Siamo</div>
    <div class="manifesto-text reveal reveal-delay-1" id="manifestoText">
        <p>Immagina uno spazio senza muri, ma con radici profonde. Questo è <strong>La Penna di Calliope</strong>, un collettivo autogestito no profit che si nutre della passione per la parola scritta e dell'energia di chi vuole condividerla.</p>
        <p>Non siamo solo un gruppo, siamo una <strong>comunità in movimento</strong>, fatta di persone vere, curiose e aperte. Qui non ci sono etichette, gerarchie o giudizi. Chiunque può entrare, sedersi e raccontarsi, indipendentemente dall'età, dal background o dalle esperienze. Ciò che conta è il desiderio di esplorare, creare e connettersi attraverso le parole.</p>
        <p>Attraverso reading, laboratori creativi, incontri informali e momenti di dialogo, diamo vita a occasioni di <strong>aggregazione culturale</strong> autentica e accessibile. La cultura non è qualcosa di lontano o impenetrabile: <em>la facciamo insieme</em>, con le nostre mani, le nostre voci, le nostre idee. Avanziamo insieme.</p>
        <p>Non abbiamo una sede fisica. Ma siamo fatti delle persone che si stringono intorno a un tavolo, a un foglio, a una storia. È questo il nostro motore: qualcosa che va oltre noi stessi e contribuisce a costruire una <strong>Napoli diversa</strong>, più sana, capace di valorizzare la cultura in tutte le sue forme — anche quella autoprodotta, spontanea, vera.</p>
        <p>Crediamo che la cultura debba essere libera e inclusiva. Per questo lavoriamo per offrire spazi dove tutti possano sentirsi accolti, dove nessuno tema di essere giudicato. Vogliamo dare voce a chi ha voglia di raccontare, ma anche orecchie a chi ha bisogno di ascoltare.</p>
    </div>
</section>

<div class="section-divider reveal">
    <div class="line"></div><div class="diamond"></div><div class="line"></div>
</div>

<!-- Il Bando -->
<section class="chi-siamo-section" id="chi-siamo">
    <div class="chi-siamo-inner">
        <div class="chi-siamo-label reveal">Il Bando</div>
        <h2 class="chi-siamo-title reveal reveal-delay-1" id="chiSiamoTitle">
            <em>Call a cavallo!</em>
        </h2>
        <div class="chi-siamo-content reveal reveal-delay-2" id="chiSiamoContent">
            <p><strong>La Penna di Calliope</strong> lancia il suo primo bando di poesia per la realizzazione di un'antologia collettiva dedicata a Napoli.</p>
            <p>Cerchiamo voci autentiche che sappiano trasformare la città in versi: la sua bellezza e le sue contraddizioni, i suoi vicoli e i suoi orizzonti, le sue ferite e la sua irriducibile vitalità.</p>
            <p>Il bando è aperto a <em>chiunque voglia partecipare</em>, senza distinzioni di età, formazione o esperienza. Scarica il documento completo per conoscere tutte le modalità di partecipazione.</p>
        </div>
    </div>
</section>

<div class="section-divider reveal">
    <div class="line"></div><div class="diamond"></div><div class="line"></div>
</div>

<!-- Timeline -->
<section class="timeline-section" id="percorso">
    <div class="timeline-inner">
        <div class="timeline-header">
            <h2 class="reveal">Il <em>percorso</em></h2>
        </div>
        <div class="timeline">
            <div class="timeline-item">
                <div class="timeline-date">Fase 01</div>
                <h3 class="timeline-title">Apertura del bando</h3>
                <p class="timeline-desc">Scarica il bando completo e invia la tua proposta poetica entro la scadenza indicata.</p>
            </div>
            <div class="timeline-item">
                <div class="timeline-date">Fase 02</div>
                <h3 class="timeline-title">Selezione della commissione</h3>
                <p class="timeline-desc">Le opere verranno valutate con attenzione, rispetto e rigore editoriale.</p>
            </div>
            <div class="timeline-item">
                <div class="timeline-date">Fase 03</div>
                <h3 class="timeline-title">Pubblicazione dell'antologia</h3>
                <p class="timeline-desc">L'antologia verrà pubblicata e presentata in eventi dedicati a Napoli.</p>
            </div>
            <div class="timeline-item">
                <div class="timeline-date">Fase 04</div>
                <h3 class="timeline-title">Presentazione e diffusione</h3>
                <p class="timeline-desc">Incontri, reading e distribuzione per dare voce alle poesie selezionate.</p>
            </div>
        </div>
    </div>
</section>

<!-- Bando CTA -->
<section class="bando-section" id="bando">
    <div class="bando-inner">
        <div class="bando-label reveal">Bando Ufficiale</div>
        <h2 class="bando-title reveal reveal-delay-1" id="bandoTitle">
            Pronto a <em>cavalcare</em>?
        </h2>
        <p class="bando-description reveal reveal-delay-2" id="bandoDesc">
            Scarica il bando completo in PDF. Troverai tutte le informazioni: modalità di partecipazione, scadenze, criteri di selezione e requisiti per inviare la tua opera poetica.
        </p>
        <!-- Direct link to bando.pdf -->
        <a href="bando.pdf" download class="bando-download reveal reveal-delay-3">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
            <span>Scarica il Bando in PDF</span>
        </a>
        <p class="bando-note reveal reveal-delay-3">Documento PDF · Aggiornato 2026</p>
    </div>
</section>

<!-- Contact -->
<section class="contact-section" id="contatti">
    <div class="contact-inner">
        <h2 class="reveal">Restiamo in <em>contatto</em></h2>
        <p class="reveal reveal-delay-1">
            Per dubbi, informazioni o per semplicemente dire che hai letto fino qui —<br>
            scrivici. La poesia è anche questo: mettersi in ascolto.
        </p>
        <div class="contact-links reveal reveal-delay-2">
            <a href="mailto:cassettadellepoesie@gmail.com" class="contact-link-item" id="contactEmail">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span id="contactEmailText">cassettadellepoesie@gmail.com</span>
            </a>
            <a href="https://instagram.com/lapennadicalliope" target="_blank" class="contact-link-item" id="contactInstagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                <span id="contactInstagramText">@lapennadicalliope</span>
            </a>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="footer">
    <div class="footer-logo">La Penna di Calliope</div>
    <p class="footer-text" id="footerText">© 2026 · Tutti i diritti riservati · Napoli, Italia</p>
    <p class="footer-tagline">«Chi ha orecchie per intendere, intenda.»</p>
    <div class="footer-social">
        <a href="https://instagram.com/lapennadicalliope" target="_blank" id="footerInstagram" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="mailto:cassettadellepoesie@gmail.com" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
    </div>
</footer>

<script>
    window.addEventListener('load', () => setTimeout(() => document.getElementById('preloader').classList.add('hidden'), 1000));

    const particles = document.getElementById('particles');
    for (let i = 0; i < 15; i++) {
        const p = document.createElement('div'); p.classList.add('particle');
        p.style.left = Math.random() * 100 + '%';
        p.style.animationDuration = (Math.random() * 15 + 10) + 's';
        p.style.animationDelay = (Math.random() * 10) + 's';
        p.style.width = (Math.random() * 3 + 1) + 'px'; p.style.height = p.style.width;
        particles.appendChild(p);
    }

    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 80) { nav.classList.add('scrolled'); nav.classList.remove('hero-nav'); }
        else { nav.classList.remove('scrolled'); nav.classList.add('hero-nav'); }
    });

    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active'); mobileMenu.classList.toggle('active');
        document.body.style.overflow = mobileMenu.classList.contains('active') ? 'hidden' : '';
    });
    document.querySelectorAll('.mobile-menu-link').forEach(l => l.addEventListener('click', () => {
        hamburger.classList.remove('active'); mobileMenu.classList.remove('active'); document.body.style.overflow = '';
    }));

    document.querySelectorAll('a[href^="#"]').forEach(a => a.addEventListener('click', function(e) {
        e.preventDefault();
        const t = document.querySelector(this.getAttribute('href'));
        if (t) window.scrollTo({ top: t.getBoundingClientRect().top + window.pageYOffset - 80, behavior: 'smooth' });
    }));

    const obs = new IntersectionObserver(entries => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }), { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.reveal, .timeline-item').forEach(el => obs.observe(el));

    window.addEventListener('scroll', () => {
        const hero = document.getElementById('hero'), s = window.scrollY;
        if (s < hero.offsetHeight) {
            const c = hero.querySelector('.hero-content');
            if (c) { c.style.opacity = Math.max(0.4, 1 - (s / hero.offsetHeight) * 0.6); c.style.transform = `translateY(${-(s * 0.15)}px)`; }
        }
    });
</script>
</body>
</html>

